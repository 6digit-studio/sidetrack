{
  "name": "@6digit/sidetrack-client",
  "version": "0.1.2",
  "description": "Development observability client - captures console, network, errors, and more. For server/CLI, see @6digit/sidetrack",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "browser": "./dist/sidetrack.js",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./browser": "./dist/sidetrack.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build.ts"
  },
  "keywords": [
    "observability",
    "debugging",
    "development",
    "logging",
    "devtools"
  ],
  "author": "6digit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/6digit-studio/sidetrack.git",
    "directory": "client"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
